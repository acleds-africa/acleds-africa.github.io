---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>

  <!-- ─── HERO ──────────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-grid" aria-hidden="true" id="heroGrid"></div>
    <div class="container hero-inner">
      <div class="hero-content">
        <p class="eyebrow">African Centre for Learning Analytics & Educational Data Science</p>
        <h1>
          Advancing Evidence&#8209;Based<br />
          Education in Africa
        </h1>
        <p class="hero-sub">
          We generate rigorous research at the intersection of learning analytics,
          educational data science, and mathematics education — to improve learning
          outcomes across Africa.
        </p>
        <div class="hero-actions">
          <a href="/research" class="btn btn-primary">Explore Research</a>
          <a href="/collaborate" class="btn btn-outline">Partner With Us</a>
        </div>
        <div class="hero-themes">
          <span>Learning Analytics</span>
          <span class="dot">·</span>
          <span>Educational Data Science</span>
          <span class="dot">·</span>
          <span>Mathematics Education</span>
        </div>
      </div>
    </div>
    <div class="hero-scroll-cue" aria-hidden="true">
      <span></span>
    </div>
  </section>

  <!-- ─── STATS BAR ─────────────────────────────────────────── -->
  <section class="stats-bar">
    <div class="container stats-inner">
      <div class="stat">
        <span class="stat-num">3+</span>
        <span class="stat-label">Research Themes</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-num">1</span>
        <span class="stat-label">Longitudinal Study</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-num">Pan&#8209;African</span>
        <span class="stat-label">Scope & Collaboration</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-num">Evidence</span>
        <span class="stat-label">Driven Policy</span>
      </div>
    </div>
  </section>

  <!-- ─── RESEARCH THEMES ───────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">What We Study</p>
        <h2>Research Themes</h2>
        <div class="divider"></div>
        <p>Our work sits at the intersection of data, learning science, and educational practice — generating insights that translate directly into improved educational outcomes.</p>
      </div>
      <div class="grid-3">
        <div class="card theme-card">
          <div class="theme-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>
          </div>
          <h3>Learning Analytics</h3>
          <p>Measuring, collecting, and analysing data about learners to understand and optimise learning and the environments in which it occurs.</p>
          <a href="/research#learning-analytics" class="card-link">View work <span>→</span></a>
        </div>
        <div class="card theme-card">
          <div class="theme-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12"/></svg>
          </div>
          <h3>Educational Data Science</h3>
          <p>Applying computational and statistical methods to education data to surface patterns that inform teaching, curriculum, and policy decisions.</p>
          <a href="/research#data-science" class="card-link">View work <span>→</span></a>
        </div>
        <div class="card theme-card">
          <div class="theme-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
          </div>
          <h3>Mathematics Education</h3>
          <p>Investigating how students develop mathematical confidence and competence, with a particular focus on longitudinal achievement trajectories in African school contexts.</p>
          <a href="/research#mathematics" class="card-link">View work <span>→</span></a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── FEATURED PROJECT ──────────────────────────────────── -->
  <section class="section section-dark">
    <div class="container">
      <div class="project-feature">
        <div class="project-feature-text">
          <p class="eyebrow" style="color: var(--gold)">Flagship Study</p>
          <h2>Longitudinal Mathematics Learning Analytics Study</h2>
          <div class="divider"></div>
          <p style="color: rgba(232,237,244,0.75)">
            A multi-year tracking study examining how mathematics confidence, identity, and achievement
            co-evolve across primary and secondary schooling — using learning analytics methods to surface
            patterns invisible to cross-sectional research.
          </p>
          <ul class="project-highlights">
            <li>
              <span class="highlight-dot"></span>
              Longitudinal design tracking cohorts over multiple years
            </li>
            <li>
              <span class="highlight-dot"></span>
              Quantitative and qualitative data integration
            </li>
            <li>
              <span class="highlight-dot"></span>
              Direct policy and curriculum implications
            </li>
          </ul>
          <a href="/projects/lmlas" class="btn btn-primary" style="margin-top:1.5rem">View Project</a>
        </div>
        <div class="project-feature-visual">
          <div class="data-visual">
            <div class="dv-label">Confidence × Achievement</div>
            <div class="dv-chart">
              <div class="dv-bar" style="--h:55%"><span>Y1</span></div>
              <div class="dv-bar" style="--h:62%"><span>Y2</span></div>
              <div class="dv-bar" style="--h:58%"><span>Y3</span></div>
              <div class="dv-bar" style="--h:74%"><span>Y4</span></div>
              <div class="dv-bar" style="--h:81%"><span>Y5</span></div>
              <div class="dv-bar" style="--h:78%"><span>Y6</span></div>
            </div>
            <div class="dv-note">Illustrative longitudinal trajectory</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── PUBLICATIONS PREVIEW ──────────────────────────────── -->
  <section class="section section-fog">
    <div class="container">
      <div class="section-header" style="display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:1rem; margin-bottom:2.5rem">
        <div>
          <p class="eyebrow">Scholarship</p>
          <h2>Recent Publications</h2>
        </div>
        <a href="/publications" class="btn btn-dark btn-sm">All Publications</a>
      </div>
      <div class="pub-list">
        <div class="pub-item">
          <span class="tag tag-gold">Working Paper</span>
          <h4>Mathematics Confidence and Achievement: A Longitudinal Perspective</h4>
          <p class="pub-meta">Grace Amackson · 2025</p>
          <a href="/publications" class="pub-link">Read →</a>
        </div>
        <div class="pub-item">
          <span class="tag">Research Brief</span>
          <h4>Applying Learning Analytics in Under-Resourced School Contexts</h4>
          <p class="pub-meta">ACLEDS Research Team · 2025</p>
          <a href="/publications" class="pub-link">Read →</a>
        </div>
        <div class="pub-item">
          <span class="tag">Conceptual Paper</span>
          <h4>Educational Data Science for African School Systems: Possibilities and Constraints</h4>
          <p class="pub-meta">ACLEDS · 2024</p>
          <a href="/publications" class="pub-link">Read →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── WHY ACLEDS ────────────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <div class="why-grid">
        <div class="why-text">
          <p class="eyebrow">Our Purpose</p>
          <h2>Research Rooted in African Contexts</h2>
          <div class="divider"></div>
          <p>
            Too much educational research applied to African schools originates elsewhere.
            ACLEDS exists to generate knowledge from within — producing scholarship that
            is contextually valid, methodologically rigorous, and policy-relevant.
          </p>
          <p style="margin-top:1rem">
            We work at the intersection of data science and education to surface insights
            that can genuinely change what happens in classrooms.
          </p>
          <a href="/about" class="btn btn-dark" style="margin-top:2rem">About ACLEDS</a>
        </div>
        <div class="why-pillars">
          <div class="pillar">
            <div class="pillar-num">01</div>
            <h4>Contextually Valid</h4>
            <p>Research designed for and conducted in African school systems, not transplanted from elsewhere.</p>
          </div>
          <div class="pillar">
            <div class="pillar-num">02</div>
            <h4>Methodologically Rigorous</h4>
            <p>Longitudinal designs, mixed methods, and transparent data practices that meet international standards.</p>
          </div>
          <div class="pillar">
            <div class="pillar-num">03</div>
            <h4>Policy-Relevant</h4>
            <p>Findings translated into clear implications for curriculum, teaching practice, and education policy.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── COLLABORATE CTA ───────────────────────────────────── -->
  <section class="section section-dark cta-section">
    <div class="container cta-inner">
      <div>
        <p class="eyebrow" style="color:var(--gold)">Get Involved</p>
        <h2>Partner With ACLEDS</h2>
        <p style="color:rgba(232,237,244,0.7); margin-top:0.75rem; max-width:52ch">
          We welcome collaboration from researchers, schools, government agencies,
          and international development partners committed to improving education in Africa.
        </p>
      </div>
      <div class="cta-actions">
        <a href="/collaborate" class="btn btn-primary">Explore Collaboration</a>
        <a href="/contact" class="btn btn-outline">Contact Us</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
/* ── Hero ── */
.hero {
  position: relative;
  background: var(--navy);
  min-height: calc(100svh - var(--nav-h));
  display: flex;
  align-items: center;
  overflow: hidden;
}

.hero-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(200,151,58,0.06) 1px, transparent 1px),
    linear-gradient(90deg, rgba(200,151,58,0.06) 1px, transparent 1px);
  background-size: 48px 48px;
  mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black, transparent);
}

.hero-inner {
  position: relative;
  z-index: 1;
  padding-top: 4rem;
  padding-bottom: 4rem;
}

.hero-content { max-width: 720px; }

.hero h1 {
  color: var(--white);
  margin: 1rem 0 1.5rem;
  font-size: clamp(2.2rem, 5vw, 3.6rem);
}

.hero-sub {
  color: rgba(232,237,244,0.7);
  font-size: clamp(1rem, 2vw, 1.15rem);
  line-height: 1.8;
  margin-bottom: 2.25rem;
  max-width: 56ch;
}

.hero-actions {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  margin-bottom: 2.5rem;
}

.hero-themes {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  flex-wrap: wrap;
  font-family: var(--font-mono);
  font-size: 0.72rem;
  letter-spacing: 0.05em;
  color: rgba(232,237,244,0.45);
}

.dot { color: var(--gold); opacity: 0.6; }

.hero-scroll-cue {
  position: absolute;
  bottom: 2rem;
  left: 50%;
  transform: translateX(-50%);
}

.hero-scroll-cue span {
  display: block;
  width: 1px;
  height: 48px;
  background: linear-gradient(to bottom, var(--gold), transparent);
  animation: scrollCue 2s ease-in-out infinite;
}

@keyframes scrollCue {
  0%, 100% { opacity: 0.3; transform: scaleY(0.7); }
  50% { opacity: 1; transform: scaleY(1); }
}

/* ── Stats ── */
.stats-bar {
  background: var(--navy-mid);
  border-bottom: 1px solid rgba(200,151,58,0.12);
}

.stats-inner {
  display: flex;
  align-items: center;
  gap: 0;
  flex-wrap: wrap;
  padding-top: 0;
  padding-bottom: 0;
}

.stat {
  flex: 1;
  min-width: 160px;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 2rem 1.5rem;
  gap: 0.25rem;
  text-align: center;
}

.stat-num {
  font-family: var(--font-display);
  font-size: clamp(1.5rem, 3vw, 2rem);
  color: var(--gold);
  line-height: 1;
}

.stat-label {
  font-size: 0.75rem;
  font-family: var(--font-mono);
  letter-spacing: 0.08em;
  color: rgba(232,237,244,0.5);
  text-transform: uppercase;
}

.stat-divider {
  width: 1px;
  height: 40px;
  background: rgba(200,151,58,0.15);
  flex-shrink: 0;
}

/* ── Theme cards ── */
.theme-icon {
  width: 52px;
  height: 52px;
  background: rgba(200,151,58,0.08);
  border: 1px solid rgba(200,151,58,0.2);
  border-radius: var(--radius-md);
  display: grid;
  place-items: center;
  color: var(--gold);
  margin-bottom: 1.25rem;
}

.theme-card h3 { margin-bottom: 0.75rem; font-size: 1.2rem; }
.theme-card p { color: var(--text-muted); font-size: 0.9rem; }

.card-link {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
  margin-top: 1.25rem;
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--gold);
  transition: gap var(--transition);
}
.card-link:hover { gap: 0.5rem; }

/* ── Featured project ── */
.project-feature {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
}

.project-highlights {
  margin-top: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.project-highlights li {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  font-size: 0.9rem;
  color: rgba(232,237,244,0.75);
}

.highlight-dot {
  width: 6px;
  height: 6px;
  background: var(--gold);
  border-radius: 50%;
  flex-shrink: 0;
}

/* Data visual */
.data-visual {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(200,151,58,0.2);
  border-radius: var(--radius-md);
  padding: 2rem;
}

.dv-label {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--gold);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-bottom: 1.5rem;
}

.dv-chart {
  display: flex;
  align-items: flex-end;
  gap: 0.75rem;
  height: 140px;
}

.dv-bar {
  flex: 1;
  height: var(--h);
  background: linear-gradient(to top, var(--gold), rgba(200,151,58,0.3));
  border-radius: 2px 2px 0 0;
  position: relative;
  transition: height 1s ease;
}

.dv-bar span {
  position: absolute;
  bottom: -1.5rem;
  left: 50%;
  transform: translateX(-50%);
  font-family: var(--font-mono);
  font-size: 0.65rem;
  color: rgba(232,237,244,0.4);
}

.dv-note {
  margin-top: 2rem;
  font-size: 0.72rem;
  color: rgba(232,237,244,0.3);
  font-style: italic;
  text-align: center;
}

/* ── Publications ── */
.pub-list {
  display: flex;
  flex-direction: column;
  gap: 0;
  border: 1px solid rgba(74,96,128,0.15);
  border-radius: var(--radius-md);
  overflow: hidden;
  background: var(--true-white);
}

.pub-item {
  padding: 1.75rem 2rem;
  border-bottom: 1px solid rgba(74,96,128,0.1);
  display: grid;
  grid-template-columns: auto 1fr auto;
  grid-template-rows: auto auto;
  gap: 0.5rem 1.25rem;
  align-items: center;
  transition: background var(--transition);
}

.pub-item:last-child { border-bottom: none; }
.pub-item:hover { background: var(--fog); }

.pub-item .tag { grid-row: 1; grid-column: 1; align-self: start; margin-top: 2px; }
.pub-item h4 { grid-row: 1; grid-column: 2; font-family: var(--font-body); font-size: 0.95rem; font-weight: 600; }
.pub-meta { grid-row: 2; grid-column: 2; font-size: 0.8rem; color: var(--text-muted); font-family: var(--font-mono); }
.pub-link { grid-row: 1 / 3; grid-column: 3; font-size: 0.85rem; font-weight: 600; color: var(--gold); white-space: nowrap; }

/* ── Why ── */
.why-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 5rem;
  align-items: start;
}

.why-text p { color: var(--text-muted); }

.why-pillars {
  display: flex;
  flex-direction: column;
  gap: 2rem;
}

.pillar { border-left: 2px solid var(--fog); padding-left: 1.5rem; }
.pillar-num {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  color: var(--gold);
  letter-spacing: 0.1em;
  margin-bottom: 0.4rem;
}
.pillar h4 { font-family: var(--font-body); font-weight: 600; margin-bottom: 0.4rem; }
.pillar p { font-size: 0.875rem; color: var(--text-muted); max-width: 42ch; }

/* ── CTA ── */
.cta-section { border-top: 1px solid rgba(200,151,58,0.1); }
.cta-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 3rem;
  flex-wrap: wrap;
}
.cta-actions { display: flex; gap: 1rem; flex-wrap: wrap; flex-shrink: 0; }

/* ── Responsive ── */
@media (max-width: 900px) {
  .project-feature { grid-template-columns: 1fr; gap: 2.5rem; }
  .why-grid { grid-template-columns: 1fr; gap: 3rem; }
}

@media (max-width: 640px) {
  .stat-divider { display: none; }
  .stat { min-width: calc(50% - 1rem); }
  .pub-item { grid-template-columns: 1fr; grid-template-rows: auto; }
  .pub-item .tag { grid-column: 1; }
  .pub-item h4 { grid-column: 1; grid-row: 2; }
  .pub-meta { grid-column: 1; grid-row: 3; }
  .pub-link { grid-column: 1; grid-row: 4; }
  .cta-inner { flex-direction: column; align-items: flex-start; }
}
</style>