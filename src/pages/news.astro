---
import BaseLayout from "../layouts/BaseLayout.astro";

const posts = [
  {
    title:
      "ACLEDS Launches the Longitudinal Mathematics Learning Analytics Study",
    date: "2025-01-15",
    dateDisplay: "15 January 2025",
    category: "Announcement",
    excerpt:
      "ACLEDS has officially launched its flagship research initiative — a multi-year study tracking how mathematics confidence and achievement develop across primary schooling using learning analytics methods.",
  },
  {
    title: "New Working Paper: Mathematics Confidence and Achievement",
    date: "2025-03-01",
    dateDisplay: "1 March 2025",
    category: "Publication",
    excerpt:
      "Grace Amackson's working paper examining the longitudinal relationship between mathematics confidence and achievement is now under review. A preprint will be made available on this site.",
  },
  {
    title: "ACLEDS Website Launches",
    date: "2025-06-01",
    dateDisplay: "June 2025",
    category: "Announcement",
    excerpt:
      "We're pleased to launch the ACLEDS website — a home for our research, team, publications, and opportunities to collaborate. The site will grow as our research programme develops.",
  },
];
---

<BaseLayout
  title="News — ACLEDS"
  description="Latest news and updates from ACLEDS"
>
  <section class="page-hero section-dark">
    <div class="container">
      <p class="eyebrow">Updates</p>
      <h1>News</h1>
      <p class="page-hero-sub">
        Announcements, publications, and developments from ACLEDS.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="news-grid">
        {
          posts
            .sort((a, b) => b.date.localeCompare(a.date))
            .map((post) => (
              <article class="news-card">
                <div class="news-meta">
                  <span class="tag">{post.category}</span>
                  <time datetime={post.date} class="news-date">
                    {post.dateDisplay}
                  </time>
                </div>
                <h3>{post.title}</h3>
                <p>{post.excerpt}</p>
              </article>
            ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: 6rem 0 5rem;
  }
  .page-hero h1 {
    color: var(--white);
    margin: 0.75rem 0 1.25rem;
  }
  .page-hero-sub {
    color: rgba(232, 237, 244, 0.7);
    font-size: 1.1rem;
    max-width: 58ch;
    line-height: 1.8;
  }

  .news-grid {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .news-card {
    padding: 2rem 2.25rem;
    background: var(--true-white);
    border: 1px solid rgba(74, 96, 128, 0.1);
    border-radius: var(--radius-md);
    transition:
      border-color var(--transition),
      box-shadow var(--transition);
  }

  .news-card:hover {
    border-color: rgba(200, 151, 58, 0.25);
    box-shadow: 0 4px 20px rgba(11, 31, 58, 0.06);
  }

  .news-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.85rem;
  }

  .news-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .news-card h3 {
    font-size: 1.15rem;
    margin-bottom: 0.6rem;
    line-height: 1.4;
  }

  .news-card p {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.75;
  }
</style>
