---
import BaseLayout from "../layouts/BaseLayout.astro";

const team = [
  {
    name: "Grace Amackson",
    role: "Founding Director & Principal Investigator",
    focus:
      "Mathematics education, longitudinal research design, learning analytics",
    bio: "Grace founded ACLEDS with a conviction that African educational systems deserve research generated from within — rigorous, contextually grounded, and oriented toward real policy impact. Her work focuses on how mathematical confidence and identity develop across schooling.",
    initials: "GA",
  },
];

const affiliates: any[] = [];
---

<BaseLayout title="Team — ACLEDS" description="Meet the ACLEDS research team">
  <section class="page-hero section-dark">
    <div class="container">
      <p class="eyebrow">The People</p>
      <h1>Our Team</h1>
      <p class="page-hero-sub">
        Researchers committed to advancing evidence-based education in Africa.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Core Team</p>
        <h2>Research Faculty</h2>
        <div class="divider"></div>
      </div>
      <div class="team-grid">
        {
          team.map((member) => (
            <div class="team-card">
              <div class="team-avatar">
                <span>{member.initials}</span>
              </div>
              <div class="team-info">
                <h3>{member.name}</h3>
                <p class="team-role">{member.role}</p>
                <p class="team-focus">
                  <>
                    <span
                      class="eyebrow"
                      style="color:var(--gold); font-size:0.65rem"
                    >
                      Focus
                    </span>
                    <br />
                  </>
                  {member.focus}
                </p>
                <p class="team-bio">{member.bio}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section-fog">
    <div class="container">
      <div class="join-cta">
        <div class="join-text">
          <p class="eyebrow">Join Us</p>
          <h2>Work With ACLEDS</h2>
          <div class="divider"></div>
          <p>
            We are always interested in connecting with researchers, graduate
            students, and practitioners whose work aligns with our mission. If
            you are interested in joining the team, collaborating on a project,
            or exploring a visiting researcher position, please reach out.
          </p>
          <a href="/contact" class="btn btn-dark" style="margin-top:2rem"
            >Get in Touch</a
          >
        </div>
        <div class="join-positions">
          <div class="card">
            <p class="eyebrow">Open to</p>
            <ul class="positions-list">
              <li>
                <div class="pos-dot"></div>
                <div>
                  <strong>Research Collaborators</strong>
                  <p>
                    Researchers working in aligned areas from any institution
                  </p>
                </div>
              </li>
              <li>
                <div class="pos-dot"></div>
                <div>
                  <strong>Graduate Students</strong>
                  <p>
                    Postgraduate students looking for supervision or
                    co-supervision
                  </p>
                </div>
              </li>
              <li>
                <div class="pos-dot"></div>
                <div>
                  <strong>School Partners</strong>
                  <p>Schools willing to participate in longitudinal studies</p>
                </div>
              </li>
              <li>
                <div class="pos-dot"></div>
                <div>
                  <strong>Visiting Researchers</strong>
                  <p>Academics visiting to collaborate on specific projects</p>
                </div>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: 6rem 0 5rem;
  }
  .page-hero h1 {
    color: var(--white);
    margin: 0.75rem 0 1.25rem;
  }
  .page-hero-sub {
    color: rgba(232, 237, 244, 0.7);
    font-size: 1.1rem;
    max-width: 58ch;
    line-height: 1.8;
  }

  .team-grid {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .team-card {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 2.5rem;
    padding: 2.5rem;
    background: var(--true-white);
    border: 1px solid rgba(74, 96, 128, 0.12);
    border-radius: var(--radius-md);
    align-items: start;
  }

  .team-avatar {
    width: 96px;
    height: 96px;
    background: var(--navy);
    border-radius: var(--radius-md);
    display: grid;
    place-items: center;
  }

  .team-avatar span {
    font-family: var(--font-display);
    font-size: 1.6rem;
    color: var(--gold);
  }

  .team-info h3 {
    font-size: 1.4rem;
    margin-bottom: 0.25rem;
  }

  .team-role {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--gold);
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }

  .team-focus {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
    line-height: 1.6;
  }

  .team-bio {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.75;
  }

  .join-cta {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .join-text p {
    color: var(--text-muted);
  }

  .positions-list {
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .positions-list li {
    display: flex;
    gap: 0.85rem;
    align-items: flex-start;
  }

  .pos-dot {
    width: 8px;
    height: 8px;
    background: var(--gold);
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 6px;
  }

  .positions-list strong {
    display: block;
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 0.2rem;
  }

  .positions-list p {
    font-size: 0.82rem;
    color: var(--text-muted);
    max-width: 100%;
    margin: 0;
  }

  @media (max-width: 768px) {
    .team-card {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .team-avatar {
      width: 72px;
      height: 72px;
    }
    .join-cta {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
