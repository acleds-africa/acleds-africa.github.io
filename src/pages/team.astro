---
import BaseLayout from "../layouts/BaseLayout.astro";

const coreTeam = [
  {
    name: "Prosper Ablordeppey",
    role: "Founding Director & Principal Investigator",
    focus:
      "Mathematics education, longitudinal research design, learning analytics",
    bio: "Prosper founded ACLEDS with a conviction that African educational systems deserve research generated from within — rigorous, contextually grounded, and oriented toward real policy impact. His work spans the full arc of the research programme: from conceptual design and methodology through to fieldwork, analysis, and dissemination. He leads the Longitudinal Mathematics Learning Analytics Study and is the driving force behind ACLEDS's research agenda.",
    initials: "PA",
  },
  {
    name: "Timothy Azirigo",
    role: "Founding Director & Senior Adviser",
    focus: "Institutional development, partnerships, strategic counsel",
    bio: "Timothy brings experience and perspective to ACLEDS as a founding director. He plays a key advisory and connective role — building relationships with institutions and partners, offering strategic counsel to the team, and helping to anchor the initiative within broader professional and academic networks.",
    initials: "TA",
  },
  {
    name: "Grace Abena Sarfoa Amackson",
    role: "Investigator",
    focus:
      "Mathematics education, learning disabilities, longitudinal research design, learning analytics",
    bio: "Grace's research sits at the intersection of mathematics education and inclusive learning. She is particularly interested in how children with learning disabilities experience and navigate mathematics — an area she believes deserves far greater research attention in African school contexts. Her work with ACLEDS contributes to both the longitudinal study design and the analysis of mathematics learning trajectories across diverse learner populations.",
    initials: "GA",
  },
];

const operations = [
  {
    name: "David D. Avemegah",
    role: "Facilitator & Administrative Coordinator",
    note: "David supports the operational side of ACLEDS — coordinating correspondence, facilitating submissions, and following up on institutional processes. He is also developing a growing interest in contributing to the research programme.",
    initials: "DA",
  },
];

const contributors: any[] = [];
---

<BaseLayout title="Team — ACLEDS" description="Meet the ACLEDS research team">
  <section class="page-hero section-dark">
    <div class="container">
      <p class="eyebrow">The People</p>
      <h1>Our Team</h1>
      <p class="page-hero-sub">
        Researchers committed to advancing evidence-based education in Africa.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Core Team</p>
        <h2>Research Faculty</h2>
        <div class="divider"></div>
      </div>
      <div class="team-grid">
        {
          coreTeam.map((member) => (
            <div class="team-card">
              <div class="team-avatar">
                <span>{member.initials}</span>
              </div>
              <div class="team-info">
                <h3>{member.name}</h3>
                <p class="team-role">{member.role}</p>
                {member.focus && (
                  <p class="team-focus">
                    <span
                      class="eyebrow"
                      style="color:var(--gold); font-size:0.65rem"
                    >
                      Focus
                    </span>
                    <br />
                    {member.focus}
                  </p>
                )}
                {member.bio && <p class="team-bio">{member.bio}</p>}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section-fog">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Operations & Administration</p>
        <h2>Operations</h2>
        <div class="divider"></div>
      </div>
      <div class="ops-grid">
        {
          operations.map((member) => (
            <div class="ops-card">
              <div class="contributor-avatar ops-avatar">
                <span>{member.initials}</span>
              </div>
              <div>
                <strong>{member.name}</strong>
                <p class="contributor-role">{member.role}</p>
                {member.note && <p class="ops-note">{member.note}</p>}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {
    contributors.length > 0 && (
      <section class="section section-fog">
        <div class="container">
          <div class="section-header">
            <p class="eyebrow">Project Contributors</p>
            <h2>Contributors</h2>
            <div class="divider" />
            <p>
              Researchers, assistants, and collaborators who have contributed to
              ACLEDS projects.
            </p>
          </div>
          <div class="contributors-grid">
            {contributors.map((c: any) => (
              <div class="contributor-card">
                <div class="contributor-avatar">
                  <span>{c.initials}</span>
                </div>
                <div>
                  <strong>{c.name}</strong>
                  <p class="contributor-role">{c.role}</p>
                  {c.project && <p class="contributor-project">{c.project}</p>}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <section class="section section-fog">
    <div class="container">
      <div class="join-cta">
        <div class="join-text">
          <p class="eyebrow">Join Us</p>
          <h2>Work With ACLEDS</h2>
          <div class="divider"></div>
          <p>
            We are always interested in connecting with researchers, graduate
            students, and practitioners whose work aligns with our mission. If
            you are interested in joining the team, collaborating on a project,
            or exploring a visiting researcher position, please reach out.
          </p>
          <a href="/contact" class="btn btn-dark" style="margin-top:2rem"
            >Get in Touch</a
          >
        </div>
        <div class="join-positions">
          <div class="card">
            <p class="eyebrow">Open to</p>
            <ul class="positions-list">
              <li>
                <div class="pos-dot"></div>
                <div>
                  <strong>Research Collaborators</strong>
                  <p>
                    Researchers working in aligned areas from any institution
                  </p>
                </div>
              </li>
              <li>
                <div class="pos-dot"></div>
                <div>
                  <strong>Graduate Students</strong>
                  <p>
                    Postgraduate students looking for supervision or
                    co-supervision
                  </p>
                </div>
              </li>
              <li>
                <div class="pos-dot"></div>
                <div>
                  <strong>School Partners</strong>
                  <p>Schools willing to participate in longitudinal studies</p>
                </div>
              </li>
              <li>
                <div class="pos-dot"></div>
                <div>
                  <strong>Visiting Researchers</strong>
                  <p>Academics visiting to collaborate on specific projects</p>
                </div>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: 6rem 0 5rem;
  }
  .page-hero h1 {
    color: var(--white);
    margin: 0.75rem 0 1.25rem;
  }
  .page-hero-sub {
    color: rgba(232, 237, 244, 0.7);
    font-size: 1.1rem;
    max-width: 58ch;
    line-height: 1.8;
  }

  .team-grid {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .team-card {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 2.5rem;
    padding: 2.5rem;
    background: var(--true-white);
    border: 1px solid rgba(74, 96, 128, 0.12);
    border-radius: var(--radius-md);
    align-items: start;
  }

  .team-avatar {
    width: 96px;
    height: 96px;
    background: var(--navy);
    border-radius: var(--radius-md);
    display: grid;
    place-items: center;
  }

  .team-avatar span {
    font-family: var(--font-display);
    font-size: 1.6rem;
    color: var(--gold);
  }

  .team-info h3 {
    font-size: 1.4rem;
    margin-bottom: 0.25rem;
  }

  .team-role {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--gold);
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }

  .team-focus {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
    line-height: 1.6;
  }

  .team-bio {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.75;
  }

  .contributors-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }

  .contributor-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem;
    background: var(--true-white);
    border: 1px solid rgba(74, 96, 128, 0.1);
    border-radius: var(--radius-md);
  }

  .contributor-avatar {
    width: 44px;
    height: 44px;
    background: var(--fog);
    border-radius: var(--radius);
    display: grid;
    place-items: center;
    font-family: var(--font-display);
    font-size: 0.85rem;
    color: var(--slate);
    flex-shrink: 0;
  }

  .ops-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.25rem;
  }

  .ops-card {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    padding: 1.5rem;
    background: var(--true-white);
    border: 1px solid rgba(74, 96, 128, 0.1);
    border-radius: var(--radius-md);
  }

  .ops-avatar {
    margin-top: 2px;
  }

  .ops-note {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-top: 0.5rem;
    line-height: 1.65;
  }

  .contributor-card strong {
    font-size: 0.9rem;
    display: block;
  }
  .contributor-role {
    font-size: 0.78rem;
    color: var(--gold);
    font-family: var(--font-mono);
    margin-top: 0.15rem;
  }
  .contributor-project {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 0.15rem;
  }

  .join-cta {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .join-text p {
    color: var(--text-muted);
  }

  .positions-list {
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .positions-list li {
    display: flex;
    gap: 0.85rem;
    align-items: flex-start;
  }

  .pos-dot {
    width: 8px;
    height: 8px;
    background: var(--gold);
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 6px;
  }

  .positions-list strong {
    display: block;
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 0.2rem;
  }

  .positions-list p {
    font-size: 0.82rem;
    color: var(--text-muted);
    max-width: 100%;
    margin: 0;
  }

  @media (max-width: 768px) {
    .team-card {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .team-avatar {
      width: 72px;
      height: 72px;
    }
    .join-cta {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
