---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact — ACLEDS" description="Get in touch with ACLEDS">
  <section class="page-hero section-dark">
    <div class="container">
      <p class="eyebrow">Reach Us</p>
      <h1>Contact</h1>
      <p class="page-hero-sub">
        Whether you have a research enquiry, a partnership proposal, or just
        want to learn more about our work — we'd like to hear from you.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="contact-layout">
        <div class="contact-info">
          <div class="info-block">
            <p class="eyebrow">General Enquiries</p>
            <a href="mailto:info@acleds.org" class="contact-link">
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                ><path
                  d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                ></path><polyline points="22,6 12,13 2,6"></polyline></svg
              >
              info@acleds.org
            </a>
          </div>

          <div class="info-block">
            <p class="eyebrow">Research Enquiries</p>
            <a href="mailto:research@acleds.org" class="contact-link">
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                ><path
                  d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                ></path><polyline points="22,6 12,13 2,6"></polyline></svg
              >
              research@acleds.org
            </a>
          </div>

          <div class="info-block">
            <p class="eyebrow">Collaboration & Partnerships</p>
            <a href="/collaborate" class="contact-link">
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                ><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"
                ></path><circle cx="9" cy="7" r="4"></circle><path
                  d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"
                ></path></svg
              >
              Use our collaboration enquiry form
            </a>
          </div>

          <div class="info-block">
            <p class="eyebrow">Response Time</p>
            <p class="info-text">
              We aim to respond to all enquiries within <strong
                >5 working days</strong
              >.
            </p>
          </div>

          <div class="social-links">
            <p class="eyebrow" style="margin-bottom:0.85rem">Follow Our Work</p>
            <div class="social-row">
              <a href="#" class="social-btn" aria-label="ResearchGate">
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  ><path
                    d="M19.586 0c-.818 0-1.508.19-2.073.565-.563.377-.97.936-1.213 1.68a12.193 12.193 0 00-.32 2.236 23.678 23.678 0 00-.064 1.677c0 .625.013 1.253.04 1.882.025.628.073 1.166.141 1.618.069.447.186.85.353 1.208.166.357.41.6.733.727.322.128.703.19 1.14.19.665 0 1.288-.148 1.867-.441.58-.294 1.097-.71 1.553-1.25V12.5h-3.513v-2.5h5.94v7h-2.428v-1.513c-.63.584-1.347 1.037-2.15 1.36-.803.323-1.65.484-2.54.484-1.01 0-1.89-.177-2.637-.53-.747-.354-1.37-.843-1.87-1.467s-.87-1.36-1.11-2.208c-.24-.847-.36-1.774-.36-2.78 0-.998.13-1.922.39-2.77.26-.849.633-1.58 1.12-2.195.486-.614 1.077-1.09 1.773-1.43.696-.34 1.476-.51 2.34-.51zm-9.22 0c-.672 0-1.29.113-1.856.34-.567.226-1.053.545-1.46.957-.407.412-.722.904-.945 1.474-.223.57-.335 1.198-.335 1.884 0 .695.108 1.327.325 1.894.217.567.52 1.054.908 1.46.388.407.857.72 1.408.941.55.22 1.16.33 1.827.33.52 0 1.013-.072 1.478-.217.465-.144.88-.353 1.245-.627.365-.273.67-.604.913-.993.244-.388.408-.827.494-1.315H10.6v-2.5h4.7v6.23H13.2v-1.12c-.37.432-.84.774-1.41 1.024-.57.25-1.21.375-1.92.375-.906 0-1.718-.17-2.436-.508-.718-.34-1.326-.81-1.824-1.414-.498-.604-.878-1.318-1.14-2.142-.263-.824-.394-1.72-.394-2.69 0-.96.133-1.852.4-2.676.267-.824.65-1.537 1.15-2.138.5-.602 1.112-1.07 1.834-1.403C8.182.166 8.99 0 9.892 0h.473z"
                  ></path></svg
                >
                ResearchGate
              </a>
              <a href="#" class="social-btn" aria-label="Twitter/X">
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  ><path
                    d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
                  ></path></svg
                >
                X (Twitter)
              </a>
            </div>
          </div>
        </div>

        <div class="contact-form-wrap">
          <h2>Send a Message</h2>
          <p
            style="color:var(--text-muted); margin:0.5rem 0 1.75rem; font-size:0.9rem"
          >
            For general questions about ACLEDS, our research, or our team.
          </p>

          <form
            class="contact-form"
            name="contact"
            method="POST"
            data-netlify="true"
          >
            <input type="hidden" name="form-name" value="contact" />

            <div class="form-row">
              <div class="field">
                <label for="c-name">Name <span class="req">*</span></label>
                <input
                  type="text"
                  id="c-name"
                  name="name"
                  required
                  placeholder="Your name"
                />
              </div>
              <div class="field">
                <label for="c-email">Email <span class="req">*</span></label>
                <input
                  type="email"
                  id="c-email"
                  name="email"
                  required
                  placeholder="your@email.com"
                />
              </div>
            </div>

            <div class="field">
              <label for="c-subject">Subject <span class="req">*</span></label>
              <input
                type="text"
                id="c-subject"
                name="subject"
                required
                placeholder="What is your message about?"
              />
            </div>

            <div class="field">
              <label for="c-message">Message <span class="req">*</span></label>
              <textarea
                id="c-message"
                name="message"
                required
                rows="6"
                placeholder="Your message..."></textarea>
            </div>

            <button
              type="submit"
              class="btn btn-primary"
              style="width:100%; justify-content:center; padding:1rem"
            >
              Send Message
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: 6rem 0 5rem;
  }
  .page-hero h1 {
    color: var(--white);
    margin: 0.75rem 0 1.25rem;
  }
  .page-hero-sub {
    color: rgba(232, 237, 244, 0.7);
    font-size: 1.1rem;
    max-width: 58ch;
    line-height: 1.8;
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 5rem;
    align-items: start;
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .info-block {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.95rem;
    color: var(--gold);
    font-weight: 500;
    transition: color var(--transition);
  }
  .contact-link:hover {
    color: var(--gold-light);
  }
  .contact-link svg {
    flex-shrink: 0;
  }

  .info-text {
    font-size: 0.9rem;
    color: var(--text-muted);
  }
  .info-text strong {
    color: var(--text);
  }

  .social-row {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .social-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.9rem;
    font-size: 0.82rem;
    font-weight: 500;
    background: var(--fog);
    border: 1px solid rgba(74, 96, 128, 0.12);
    border-radius: var(--radius);
    color: var(--slate);
    transition:
      border-color var(--transition),
      color var(--transition),
      background var(--transition);
  }
  .social-btn:hover {
    border-color: var(--gold);
    color: var(--navy);
    background: rgba(200, 151, 58, 0.06);
  }

  .contact-form-wrap h2 {
    font-size: 1.6rem;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  label {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text);
  }
  .req {
    color: var(--gold);
  }

  input,
  textarea {
    font-family: var(--font-body);
    font-size: 0.9rem;
    padding: 0.7rem 0.95rem;
    border: 1.5px solid rgba(74, 96, 128, 0.2);
    border-radius: var(--radius);
    background: var(--white);
    color: var(--text);
    transition:
      border-color var(--transition),
      box-shadow var(--transition);
    outline: none;
    width: 100%;
  }
  input:focus,
  textarea:focus {
    border-color: var(--gold);
    box-shadow: 0 0 0 3px rgba(200, 151, 58, 0.1);
  }
  input::placeholder,
  textarea::placeholder {
    color: #aab4c0;
  }
  textarea {
    resize: vertical;
    min-height: 140px;
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .contact-layout {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
  @media (max-width: 600px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
