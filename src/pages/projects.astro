---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Projects — ACLEDS"
  description="Active and completed research projects at ACLEDS"
>
  <section class="page-hero section-dark">
    <div class="container">
      <p class="eyebrow">Active Research</p>
      <h1>Projects</h1>
      <p class="page-hero-sub">
        Ongoing studies and research initiatives within the ACLEDS programme.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="project-card flagship">
        <div class="project-card-header">
          <div>
            <span class="tag tag-gold">Flagship Study</span>
            <span class="project-status active">Active</span>
          </div>
          <span class="project-year">2024 — ongoing</span>
        </div>
        <h2>Longitudinal Mathematics Learning Analytics Study</h2>
        <p class="project-abbr">LMLAS</p>
        <div class="divider"></div>
        <p class="project-description">
          The LMLAS is a multi-year tracking study examining how mathematics
          confidence, identity, and measurable achievement develop across the
          primary and lower secondary school years — using the methods of
          learning analytics to surface patterns that cross-sectional research
          cannot capture.
        </p>
        <p class="project-description">
          The study follows cohorts of learners over multiple years, combining
          standardised assessments, teacher observations, learner surveys, and
          administrative data. The result is a rich longitudinal dataset that
          can support multiple lines of analysis.
        </p>

        <div class="project-details-grid">
          <div class="project-detail">
            <p class="eyebrow">Design</p>
            <p>Longitudinal, mixed methods</p>
          </div>
          <div class="project-detail">
            <p class="eyebrow">Themes</p>
            <p>Mathematics education, Learning analytics</p>
          </div>
          <div class="project-detail">
            <p class="eyebrow">Status</p>
            <p>Data collection ongoing</p>
          </div>
          <div class="project-detail">
            <p class="eyebrow">Duration</p>
            <p>Multi-year</p>
          </div>
        </div>

        <div class="project-rqs">
          <h4>Research Questions</h4>
          <ol>
            <li>
              How do mathematics confidence and achievement co-evolve across the
              primary school years?
            </li>
            <li>
              What learner, teacher, and school factors predict positive
              mathematics trajectories?
            </li>
            <li>
              How does mathematical identity interact with achievement outcomes
              over time?
            </li>
            <li>
              What do learning analytics approaches reveal that traditional
              assessment cannot?
            </li>
          </ol>
        </div>

        <div class="project-actions">
          <a href="/publications" class="btn btn-dark btn-sm"
            >Related Publications</a
          >
          <a href="/collaborate" class="btn btn-primary btn-sm"
            >Enquire About Partnership</a
          >
        </div>
      </div>
    </div>
  </section>

  <section class="section section-fog">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Coming Next</p>
        <h2>Pipeline</h2>
        <div class="divider"></div>
        <p>Research initiatives in development at ACLEDS.</p>
      </div>
      <div class="grid-3">
        <div class="card pipeline-card">
          <span class="tag">In Development</span>
          <h4>Learning Analytics Methods for Low-Infrastructure Contexts</h4>
          <p>
            Developing a methodological toolkit adapted to schools with limited
            digital infrastructure.
          </p>
        </div>
        <div class="card pipeline-card">
          <span class="tag">Planned</span>
          <h4>Teacher Practices and Mathematics Outcomes</h4>
          <p>
            Examining how specific pedagogical practices correlate with
            longitudinal achievement trajectories.
          </p>
        </div>
        <div class="card pipeline-card">
          <span class="tag">Planned</span>
          <h4>School Partnership Network</h4>
          <p>
            Building a network of collaborating schools to support larger-scale
            longitudinal data collection.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: 6rem 0 5rem;
  }
  .page-hero h1 {
    color: var(--white);
    margin: 0.75rem 0 1.25rem;
  }
  .page-hero-sub {
    color: rgba(232, 237, 244, 0.7);
    font-size: 1.1rem;
    max-width: 58ch;
    line-height: 1.8;
  }

  .project-card {
    background: var(--true-white);
    border: 1px solid rgba(74, 96, 128, 0.12);
    border-radius: var(--radius-md);
    padding: 2.5rem;
  }

  .project-card.flagship {
    border-color: rgba(200, 151, 58, 0.25);
    box-shadow:
      0 0 0 1px rgba(200, 151, 58, 0.08),
      0 8px 32px rgba(11, 31, 58, 0.06);
  }

  .project-card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .project-card-header > div {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .project-status {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.2rem 0.6rem;
    border-radius: 2px;
  }

  .project-status.active {
    background: rgba(34, 197, 94, 0.1);
    color: #16a34a;
  }

  .project-year {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .project-card h2 {
    margin-top: 0.5rem;
    font-size: clamp(1.4rem, 3vw, 2rem);
  }

  .project-abbr {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--gold);
    letter-spacing: 0.1em;
    margin-top: 0.25rem;
    margin-bottom: 0.5rem;
  }

  .project-description {
    color: var(--text-muted);
    margin-top: 1rem;
  }

  .project-details-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 1.5rem;
    margin: 2rem 0;
    padding: 1.75rem;
    background: var(--fog);
    border-radius: var(--radius);
  }

  .project-detail .eyebrow {
    margin-bottom: 0.3rem;
    font-size: 0.65rem;
  }
  .project-detail p:last-child {
    font-size: 0.875rem;
    color: var(--text);
  }

  .project-rqs {
    margin-top: 1.5rem;
    padding: 1.5rem;
    border: 1px solid rgba(74, 96, 128, 0.12);
    border-radius: var(--radius);
  }

  .project-rqs h4 {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1rem;
  }

  .project-rqs ol {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    counter-reset: rq;
  }

  .project-rqs li {
    font-size: 0.875rem;
    color: var(--text-muted);
    padding-left: 2rem;
    position: relative;
    counter-increment: rq;
  }

  .project-rqs li::before {
    content: counter(rq, decimal-leading-zero);
    position: absolute;
    left: 0;
    top: 0;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--gold);
    font-weight: 500;
  }

  .project-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--fog);
  }

  .pipeline-card h4 {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.95rem;
    margin: 0.75rem 0 0.5rem;
  }

  .pipeline-card p {
    font-size: 0.875rem;
    color: var(--text-muted);
  }
</style>
